{
  "cameras": {
    "left_rtsp": "rtsp://admin:password@left-camera.example.invalid:554/cam/realmonitor?channel=1&subtype=0",
    "right_rtsp": "rtsp://admin:password@right-camera.example.invalid:554/cam/realmonitor?channel=1&subtype=0"
  },
  "paths": {
    "homography_file": "data/runtime_homography.json",
    "calibration_debug_dir": "output/calibration"
  },
  "runtime": {
    "output_standard": "realtime_hq_1080p",
    "input_runtime": "ffmpeg-cuda",
    "input_pipe_format": "nv12",
    "rtsp_transport": "udp",
    "input_buffer_frames": 8,
    "rtsp_timeout_sec": 10.0,
    "reconnect_cooldown_sec": 0.5,
    "pair_reuse_max_age_ms": 140.0,
    "pair_reuse_max_consecutive": 4,
    "sync_time_source": "pts-offset-auto",
    "sync_match_max_delta_ms": 35.0,
    "sync_manual_offset_ms": 0.0,
    "sync_auto_offset_window_sec": 4.0,
    "sync_auto_offset_max_search_ms": 500.0,
    "sync_recalibration_interval_sec": 60.0,
    "sync_recalibration_trigger_skew_ms": 45.0,
    "sync_recalibration_trigger_wait_ratio": 0.5,
    "sync_auto_offset_confidence_min": 0.85,
    "distortion_mode": "runtime-lines",
    "use_saved_distortion": true,
    "distortion_auto_save": true,
    "left_distortion_file": "data/runtime_distortion_left.json",
    "right_distortion_file": "data/runtime_distortion_right.json",
    "distortion_lens_model_hint": "auto",
    "distortion_horizontal_fov_deg": 0.0,
    "distortion_vertical_fov_deg": 0.0,
    "distortion_camera_model": "",
    "status_interval_sec": 5.0,
    "viewer_backend": "auto",
    "output_cadence_fps": 30.0,
    "probe": {
      "source": "standalone",
      "runtime": "ffmpeg",
      "target": "udp://127.0.0.1:23000?pkt_size=1316"
    },
    "transmit": {
      "runtime": "gpu-direct",
      "target": "udp://127.0.0.1:24000?pkt_size=1316",
      "bitrate": "16M",
      "preset": "p4",
      "width": 0,
      "height": 0,
      "debug_overlay": true
    }
  }
}
